{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Permissioned Action Request",
  "description": "Caris contract for a typed side-effect request.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "jobId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "runtime": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "activeProfile": {
      "type": "string",
      "enum": [
        "flutter",
        "nextjs_react",
        "universal"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "write",
        "apply",
        "execute",
        "release",
        "publish"
      ]
    },
    "requestedBy": {
      "type": "string",
      "minLength": 1
    },
    "justification": {
      "type": "string",
      "minLength": 1
    },
    "riskTier": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },
    "auditRoute": {
      "type": "string",
      "enum": [
        "self_certify",
        "standard_audit",
        "stop_and_think"
      ]
    },
    "targetPaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "expectedOutputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "requiredEnvKeys": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      },
      "uniqueItems": true
    },
    "requiresHumanApproval": {
      "type": "boolean"
    }
  },
  "required": [
    "id",
    "jobId",
    "runtime",
    "activeProfile",
    "action",
    "requestedBy",
    "justification",
    "riskTier",
    "auditRoute",
    "targetPaths",
    "expectedOutputs",
    "requiredEnvKeys",
    "requiresHumanApproval"
  ]
}
