{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance Job Manifest",
  "description": "Caris contract for a single curated governance job definition.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "activeProfile": {
      "type": "string",
      "enum": [
        "flutter",
        "nextjs_react",
        "universal"
      ]
    },
    "requiredEnvKeys": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      },
      "uniqueItems": true
    },
    "riskTier": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },
    "allowedActions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "write",
          "apply",
          "execute",
          "release",
          "publish"
        ]
      },
      "uniqueItems": true
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "outputId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "file",
              "directory",
              "report",
              "bundle",
              "artifact",
              "log"
            ]
          }
        },
        "required": [
          "outputId",
          "description",
          "path",
          "kind"
        ]
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auditRoute": {
          "type": "string",
          "enum": [
            "self_certify",
            "standard_audit",
            "stop_and_think"
          ]
        },
        "hardGateIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "uniqueItems": true
        },
        "requiresWhitelistValidation": {
          "type": "boolean"
        },
        "requiresSchemaValidation": {
          "type": "boolean"
        }
      },
      "required": [
        "auditRoute",
        "hardGateIds",
        "requiresWhitelistValidation",
        "requiresSchemaValidation"
      ]
    },
    "runsParser": {
      "type": "boolean"
    },
    "requiresZip": {
      "type": "boolean"
    }
  },
  "required": [
    "id",
    "title",
    "description",
    "runtime",
    "activeProfile",
    "requiredEnvKeys",
    "riskTier",
    "allowedActions",
    "outputs",
    "gates",
    "runsParser",
    "requiresZip"
  ]
}
